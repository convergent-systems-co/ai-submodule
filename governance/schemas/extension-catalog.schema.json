{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://set-apps.github.io/dark-forge/schemas/extension-catalog.schema.json",
  "title": "Extension Catalog",
  "description": "Auto-generated catalog of discovered extensions (panels, phases, hooks). Generated by extension_discovery.py; do not edit manually.",
  "type": "object",
  "required": ["generated_at", "total_extensions", "panels", "phases", "hooks"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the catalog was generated."
    },
    "total_extensions": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of discovered extensions across all types."
    },
    "panels": {
      "type": "array",
      "description": "Discovered custom panel prompts.",
      "items": {
        "type": "object",
        "required": ["name", "type", "path"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Panel identifier."
          },
          "type": {
            "type": "string",
            "const": "panel"
          },
          "path": {
            "type": "string",
            "description": "File path to the panel prompt."
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "author": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "phases": {
      "type": "array",
      "description": "Discovered custom orchestrator phase scripts.",
      "items": {
        "type": "object",
        "required": ["name", "type", "path"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Phase script identifier."
          },
          "type": {
            "type": "string",
            "const": "phase"
          },
          "path": {
            "type": "string",
            "description": "File path to the phase script."
          },
          "description": {
            "type": "string"
          },
          "after_phase": {
            "type": ["integer", "null"],
            "description": "Execute this phase after the specified orchestrator phase number."
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0,
            "default": 300
          },
          "interpreter": {
            "type": "string",
            "enum": ["bash", "python3"],
            "default": "bash"
          }
        },
        "additionalProperties": false
      }
    },
    "hooks": {
      "type": "array",
      "description": "Discovered lifecycle hook scripts.",
      "items": {
        "type": "object",
        "required": ["name", "type", "path", "hook_point"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Hook script identifier."
          },
          "type": {
            "type": "string",
            "const": "hook"
          },
          "path": {
            "type": "string",
            "description": "File path to the hook script."
          },
          "hook_point": {
            "type": "string",
            "enum": ["pre_dispatch", "post_merge", "post_review"],
            "description": "Lifecycle point where this hook executes."
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0,
            "default": 60
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

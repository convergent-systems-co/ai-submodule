  "title": "Add user authentication via JWT",
  "description": "Implement JWT-based authentication for the REST API. Users authenticate with email/password and receive a signed JWT. Protected endpoints validate the token via middleware.",
  "origin": "human",
  "issue_ref": "#42",
  "acceptance_criteria": [
    {
      "id": "AC-1",
      "description": "POST /auth/login accepts email and password, returns a signed JWT on success",
      "verification_method": "automated_test",
      "verification_target": "tests/auth/test_login.py::test_login_success",
      "priority": "must"
    },
    {
      "id": "AC-2",
      "description": "JWT contains user ID, email, and expiration claims",
      "verification_method": "automated_test",
      "verification_target": "tests/auth/test_token.py::test_jwt_claims",
      "priority": "must"
    },
    {
      "id": "AC-3",
      "description": "Protected endpoints return 401 when no token is provided",
      "verification_method": "automated_test",
      "verification_target": "tests/auth/test_middleware.py::test_unauthenticated_request",
      "priority": "must"
    },
    {
      "id": "AC-4",
      "description": "Token expiration is configurable via environment variable",
      "verification_method": "grep_match",
      "verification_target": "JWT_EXPIRATION.*os.environ",
      "priority": "should"
    },
    {
      "id": "AC-5",
      "description": "Security review panel approves the authentication implementation",
      "verification_method": "panel_emission",
      "verification_target": "security-review",
      "priority": "must"
    }
  ],
